# === API Keys ===
OPENAI_API_KEY=sk-your-key-here

# === Model Configuration ===
FAST_MODEL=gpt-4o-mini
DEFAULT_MODEL=gpt-4o
REASONING_MODEL=o3

# === Agent Behaviour ===
MAX_ITERATIONS=30
STALL_THRESHOLD=5
CONTEXT_LIMIT_PERCENT=80
TOOL_OUTPUT_MAX_CHARS=4000
MAX_COST_PER_CHALLENGE=2.00

# === Tool Timeouts (seconds) ===
TOOL_TIMEOUT_SHELL=30
TOOL_TIMEOUT_PYTHON=60
TOOL_TIMEOUT_NETWORK=30

# === Sandbox ===
SANDBOX_MODE=docker
DOCKER_IMAGE=ctf-agent-sandbox
DOCKER_MEM=512m
DOCKER_CPU_QUOTA=50000

# === Logging ===
LOG_LEVEL=INFO
LOG_DIR=logs
SESSION_DIR=sessions
